# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Next.js build output ──────────────────────────────────
.next/
out/
build/
dist/
*.tsbuildinfo

# ── Environment (never commit) ────────────────────────────
# CLAUDE.md §10 참조: .env.local 은 supabase status / vercel env 로부터 재생성.
# .env.example 만 의도적으로 추적할 경우 `!.env.example` 로 화이트리스트.
.env
.env.*
.envrc

# ── Testing ───────────────────────────────────────────────
coverage/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/.playwright-mcp/

# ── Logs ──────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# ── Vercel CLI (프로젝트 연결 메타) ─────────────────────────
.vercel

# ── Supabase CLI (로컬 컨테이너 런타임 생성 파일) ───────────
# 주의: supabase/config.toml · supabase/migrations(쓰지 않지만 CLI가 생성 시도) 는 커밋.
supabase/.temp/
supabase/.branches/

# ── Drizzle 런타임 (생성 마이그레이션·메타는 커밋) ───────────
# drizzle/ 디렉토리 자체는 추적. drizzle-kit studio 등의 캐시만 제외.
drizzle/.cache/

# ── IDE / Editor ──────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db

# ── Claude Code — per-machine settings only ───────────────
# .claude/skills/ 는 프로젝트 공용이므로 커밋 대상.
.claude/settings.local.json

# ── oh-my-claudecode 세션 상태 ─────────────────────────────
.omc/
