{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Read(node_modules/**)",
      "Read(.next/**)",
      "Read(dist/**)",
      "Read(build/**)",
      "Read(.turbo/**)",
      "Read(.swc/**)",
      "Read(.cache/**)",
      "Read(coverage/**)",
      "Read(.vitest/**)",
      "Read(playwright-report/**)",
      "Read(test-results/**)",
      "Read(package-lock.json)",
      "Read(yarn.lock)",
      "Read(pnpm-lock.yaml)",
      "Read(drizzle/meta/**)",
